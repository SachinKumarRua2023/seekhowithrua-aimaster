# Copy this to .env and add your actual API key
# Get your API key from: https://ai.google.dev/

GEMMA_API_KEY=your_gemini_api_key_here
NODE_ENV=production
PORT=3000

# Note: You need a Google AI Studio API key (formerly Gemini API)
# Gemma 4 models are accessed through the Gemini API
# This backend ONLY uses Gemma 4 (no other providers)

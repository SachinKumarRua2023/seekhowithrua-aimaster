{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/aiMaster",
      "dest": "/aiMaster/index.html"
    },
    {
      "src": "/aiMaster/(.*)",
      "dest": "/aiMaster/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
